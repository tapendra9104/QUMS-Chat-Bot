# Auto detect text files and perform LF normalization
* text=auto

# Force LF on all Python files
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sh text eol=lf

# Force CRLF on Windows-specific files
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.sqlite3 binary
*.svg text eol=lf
